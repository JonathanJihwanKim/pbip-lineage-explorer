        {"Column": {"Expression": {"SourceRef": {"Source": "s"}}, "Property": "Quantity"}, "Name": "Sales.Quantity"},
        {"Measure": {"Expression": {"SourceRef": {"Source": "s"}}, "Property": "Total Sales"}, "Name": "Sales.Total Sales"}
